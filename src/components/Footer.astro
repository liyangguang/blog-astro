---
import HeaderLink from '@components/HeaderLink.astro';

const links = [
  {
    href: "https://www.linkedin.com/in/yangguangli/",
    label: "LinkedIn",
  },
  {
    href: "mailto:hi@yangguang.li",
    label: "Email",
  },
  {
    href: "https://github.com/liyangguang",
    label: "GitHub",
  },
  {
    href: "https://twitter.com/LYangguang",
    label: "Twitter",
  },
  {
    href: "/rss.xml",
    label: "RSS",
  },
];

---

<footer>
  {links.map((link) => (
    <HeaderLink href={link.href} external>
      {link.label}
    </HeaderLink>
  ))}
</footer>

<style>
	body > footer {
		font-size: .95em;
		margin-top: 8em;
		padding: 2em 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 2em;
		border: 0;
	}
</style>
